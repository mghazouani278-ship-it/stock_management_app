PORT=5000
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
NODE_ENV=development

# Firebase - Projet "Management Depot"
# Créez un projet Firebase nommé "Management Depot" (ID ex: management-depot)
# Option 1 : placez la clé JSON dans backend/config/firebase-service-account.json
# Option 2 : variable avec le JSON (une seule ligne)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"management-depot",...}
# Optionnel : forcer l'ID projet
# FIREBASE_PROJECT_ID=management-depot